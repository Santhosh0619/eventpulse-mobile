# Expo only exposes env vars prefixed with EXPO_PUBLIC_ to the JS runtime.
# Copy this file to .env and fill in real values.

# Backend API base URL. On a physical device use your machine's LAN IP, e.g.
# http://192.168.1.10:8000 — "localhost" points at the device itself.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=xxxxx
